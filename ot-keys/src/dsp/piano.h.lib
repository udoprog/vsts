// Usage: faustifiedLookupTable(89,3, 93,2), 2, 50, 89, 108);
LookupTable(pairs, count, sample_count, range_min, range_max, value) = result with {
	start = ba.bpf.start(x, y) with {
		x = ba.take(1, pairs);
		y = ba.take(2, pairs);
	};
	points = seq(i, count-2, ba.bpf.point(x, y) with {
		x = ba.take(3 + i*2, pairs);
		y = ba.take(4 + i*2, pairs);
	});
	end = ba.bpf.end(x, y) with {
		x = ba.take(count*2-1, pairs);
		y = ba.take(count*2, pairs);
	};

	bpf = start : points : end;

	// Raw results
	//result = value:bpf;

	// Use a lookup table
	result = ba.tabulate(1, bpf, sample_count, range_min, range_max, value).lin;
};


